#!/usr/bin/env bash

if [[ $# -eq 1 ]]; then
    selected=$1
else
    if [[ $(defaults read -g AppleInterfaceStyle 2> /dev/null) == Dark ]]; then
        fzf_color='bg:-1,bg+:#1f2933,gutter:-1,fg:#d0d0d0,fg+:#ffffff,hl:#7dcfff,hl+:#7dcfff,prompt:#7dcfff,pointer:#ff9e64'
    else
        fzf_color='bg:-1,bg+:#e8dfd2,gutter:-1,fg:#1f2933,fg+:#111111,hl:#2f6f9f,hl+:#2f6f9f,prompt:#2f6f9f,pointer:#d14d72'
    fi

    selected=$(
        {
            for dir in "$HOME/Projects" "$HOME/vpn" "/etc/nixos" "$HOME/.dotfiles" ; do
                if [[ -d $dir ]]; then
                    find "$dir" -mindepth 1 -maxdepth 1
                fi
            done

            if [[ -d $HOME/.dotfiles ]]; then
                printf '%s\n' "$HOME/.dotfiles"
            fi
        } | fzf --color="$fzf_color"
    )
fi

if [[ -z $selected ]]; then
    exit 0
fi

# If selected is a file, get its parent directory
if [[ -f $selected ]]; then
    selected=$(dirname "$selected")
fi

selected_name=$(basename "$selected" | tr . _)

if ! tmux has-session -t "$selected_name" 2> /dev/null; then
    tmux new-session -d -s "$selected_name" -n 'jj' -c "$selected"
    tmux new-window -t "$selected_name" -n 'pi' -c "$selected"
    tmux send-keys -t "$selected_name:pi" 'pi' Enter
    tmux select-window -t "$selected_name:jj"
fi

if [[ -z $TMUX ]]; then
    tmux attach-session -t "$selected_name"
else
    tmux switch-client -t "$selected_name"
fi
