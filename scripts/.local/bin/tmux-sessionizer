#!/usr/bin/env bash

if [[ $# -eq 1 ]]; then
    selected=$1
else
    selected=$(
        {
            for dir in "$HOME/Projects" "$HOME/vpn" "/etc/nixos"; do
                if [[ -d $dir ]]; then
                    find "$dir" -mindepth 1 -maxdepth 1
                fi
            done

            if [[ -d $HOME/.dotfiles ]]; then
                printf '%s\n' "$HOME/.dotfiles"
            fi
        } | fzf
    )
fi

if [[ -z $selected ]]; then
    exit 0
fi

# If selected is a file, get its parent directory
if [[ -f $selected ]]; then
    selected=$(dirname "$selected")
fi

selected_name=$(basename "$selected" | tr . _)

if ! tmux has-session -t "$selected_name" 2> /dev/null; then
    tmux new-session -d -s "$selected_name" -n 'nvim (j)' -c "$selected"
    tmux send-keys -t "$selected_name:1" 'nvim' Enter
    tmux new-window -t "$selected_name" -n 'git (k)' -c "$selected"
    tmux new-window -t "$selected_name" -n 'codex (l)' -c "$selected"
    tmux send-keys -t "$selected_name:3" 'codex' Enter
    tmux select-window -t "$selected_name:1"
fi

if [[ -z $TMUX ]]; then
    tmux attach-session -t "$selected_name"
else
    tmux switch-client -t "$selected_name"
fi
